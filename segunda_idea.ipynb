import numpy as np
import matplotlib.pyplot as plt

# 1. REGRESIÓN

def sigmoid(x):
    return 1 / (1 + np.exp(-x))

# Datos de ejemplo
x = np.linspace(-10, 10, 100)
y = sigmoid(0.5 * x - 1)

# Gráfica
plt.figure()
plt.plot(x, y)
plt.title("Función Sigmoide (Regresión Logística)")
plt.xlabel("x")
plt.ylabel("p(x)")
plt.grid()
plt.show()

# 2. SVM (MARGEN)

# Simulación simple del margen
w = np.array([1, -1])
b = 0

# Crear puntos
X = np.random.randn(100, 2)
y = np.sign(X @ w + b)

# Graficar puntos
plt.figure()
plt.scatter(X[:, 0], X[:, 1], c=y)

# Línea de separación
x_line = np.linspace(-2, 2, 100)
y_line = (w[0]*x_line + b) / -w[1]
plt.plot(x_line, y_line)

plt.title("Separación SVM (hiperplano)")
plt.grid()
plt.show()

# 3. LSTM (SIMULACIÓN ECUACIONES)

# Funciones de activación
def tanh(x):
    return np.tanh(x)

# Estado anterior
C_prev = 0.5
h_prev = 0.2
x_t = 0.8

# Pesos (ejemplo)
Wf, Wi, Wc, Wo = 0.5, 0.6, 0.7, 0.8
bf, bi, bc, bo = 0.1, 0.1, 0.1, 0.1

# Puertas
f_t = sigmoid(Wf * (h_prev + x_t) + bf)
i_t = sigmoid(Wi * (h_prev + x_t) + bi)
C_tilde = tanh(Wc * (h_prev + x_t) + bc)

# Estado de celda
C_t = f_t * C_prev + i_t * C_tilde

# Salida
o_t = sigmoid(Wo * (h_prev + x_t) + bo)
h_t = o_t * tanh(C_t)

print("f_t:", f_t)
print("i_t:", i_t)
print("C_t:", C_t)
print("h_t:", h_t)
